<!-- Colors.xaml - Version 1.0 -->
<!-- Toutes les couleurs de l'application centralisées ici -->
<!-- Pour changer le thème : modifier uniquement ce fichier -->

<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Couleurs de fond -->
    <SolidColorBrush x:Key="BackgroundDark"       Color="#1E1E1E"/>
    <SolidColorBrush x:Key="BackgroundMedium"     Color="#252526"/>
    <SolidColorBrush x:Key="BackgroundLight"      Color="#2D2D30"/>
    <SolidColorBrush x:Key="BackgroundInput"      Color="#3F3F46"/>

    <!-- Couleur d'accentuation -->
    <SolidColorBrush x:Key="AccentColor"          Color="#007ACC"/>
    <SolidColorBrush x:Key="AccentColorHover"     Color="#005A9E"/>
    <SolidColorBrush x:Key="AccentColorPressed"   Color="#004E8C"/>

    <!-- Couleurs de texte -->
    <SolidColorBrush x:Key="TextPrimary"          Color="#F1F1F1"/>
    <SolidColorBrush x:Key="TextSecondary"        Color="#CCCCCC"/>
    <SolidColorBrush x:Key="TextMuted"            Color="#808080"/>

    <!-- Couleurs de bordure -->
    <SolidColorBrush x:Key="BorderColor"          Color="#3F3F46"/>
    <SolidColorBrush x:Key="BorderAccent"         Color="#007ACC"/>

    <!-- Couleurs des boutons -->
    <SolidColorBrush x:Key="ButtonBackground"     Color="#2D2D30"/>
    <SolidColorBrush x:Key="ButtonHover"          Color="#3E3E42"/>

    <!-- Couleur fermeture fenêtre -->
    <SolidColorBrush x:Key="CloseButtonHover"     Color="#E81123"/>

    <!-- Overlay chargement -->
    <SolidColorBrush x:Key="LoadingOverlay"       Color="#AA000000"/>

</ResourceDictionary>
