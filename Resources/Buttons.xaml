<!-- Buttons.xaml - Version 1.0 -->
<!-- Styles de tous les boutons de l'application -->
<!-- Dépend de Colors.xaml et Sizes.xaml -->

<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Bouton standard -->
    <Style x:Key="ModernButton" TargetType="Button">
        <Setter Property="Background"   Value="{StaticResource ButtonBackground}"/>
        <Setter Property="Foreground"   Value="{StaticResource TextPrimary}"/>
        <Setter Property="BorderBrush"  Value="{StaticResource BorderColor}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding"      Value="{StaticResource PaddingButtonNormal}"/>
        <Setter Property="FontSize"     Value="{StaticResource FontSizeNormal}"/>
        <Setter Property="Cursor"       Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{StaticResource CornerRadiusCard}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Margin="{TemplateBinding Padding}"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource ButtonHover}"/>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="{StaticResource AccentColor}"/>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.5"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Bouton Exécuter : fond bleu -->
    <Style x:Key="ExecuteButton" TargetType="Button" BasedOn="{StaticResource ModernButton}">
        <Setter Property="Background"  Value="{StaticResource AccentColor}"/>
        <Setter Property="FontWeight"  Value="SemiBold"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource AccentColorHover}"/>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="{StaticResource AccentColorPressed}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Bouton sidebar : alignement gauche, pas de hover qui écrase la sélection -->
    <Style x:Key="SidebarButton" TargetType="Button">
        <Setter Property="Foreground"      Value="{StaticResource TextPrimary}"/>
        <Setter Property="BorderBrush"     Value="{StaticResource BorderColor}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding"         Value="{StaticResource PaddingButtonNormal}"/>
        <Setter Property="FontSize"        Value="{StaticResource FontSizeNormal}"/>
        <Setter Property="Cursor"          Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{StaticResource CornerRadiusCard}">
                        <ContentPresenter HorizontalAlignment="Left"
                                          VerticalAlignment="Center"
                                          Margin="{TemplateBinding Padding}"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Bouton fermeture fenêtre -->
    <Style x:Key="CloseButton" TargetType="Button">
        <Setter Property="Background"      Value="Transparent"/>
        <Setter Property="Foreground"      Value="White"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="FontSize"        Value="{StaticResource FontSizeMedium}"/>
        <Setter Property="FontWeight"      Value="Bold"/>
        <Setter Property="Cursor"          Value="Hand"/>
        <Setter Property="Width"           Value="{StaticResource WindowButtonWidth}"/>
        <Setter Property="Height"          Value="{StaticResource WindowButtonHeight}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource CloseButtonHover}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Bouton minimiser fenêtre -->
    <Style x:Key="MinimizeButton" TargetType="Button">
        <Setter Property="Background"      Value="Transparent"/>
        <Setter Property="Foreground"      Value="White"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="FontSize"        Value="{StaticResource FontSizeLarge}"/>
        <Setter Property="FontWeight"      Value="Bold"/>
        <Setter Property="Cursor"          Value="Hand"/>
        <Setter Property="Width"           Value="{StaticResource WindowButtonWidth}"/>
        <Setter Property="Height"          Value="{StaticResource WindowButtonHeight}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource ButtonHover}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

</ResourceDictionary>
