<!-- Sizes.xaml - Version 1.1 -->
<!-- Changelog : ResultLabelWidth passe de sys:Double à GridLength -->
<!--             pour compatibilité avec ColumnDefinition Width=   -->

<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- Largeur de la sidebar -->
    <GridLength x:Key="SidebarWidth">250</GridLength>

    <!-- Hauteur barre de titre -->
    <GridLength x:Key="TitleBarHeight">40</GridLength>

    <!-- Hauteur barre de statut -->
    <GridLength x:Key="StatusBarHeight">30</GridLength>

    <!-- Tailles de police -->
    <sys:Double x:Key="FontSizeSmall">11</sys:Double>
    <sys:Double x:Key="FontSizeNormal">13</sys:Double>
    <sys:Double x:Key="FontSizeMedium">14</sys:Double>
    <sys:Double x:Key="FontSizeLarge">16</sys:Double>
    <sys:Double x:Key="FontSizeTitle">20</sys:Double>
    <sys:Double x:Key="FontSizeSection">12</sys:Double>

    <!-- Marges standards -->
    <Thickness x:Key="MarginPage">20</Thickness>
    <Thickness x:Key="MarginSection">0,0,0,15</Thickness>
    <Thickness x:Key="MarginItem">0,0,0,8</Thickness>
    <Thickness x:Key="MarginSidebar">15</Thickness>
    <Thickness x:Key="MarginSidebarTitle">15,15,15,10</Thickness>
    <Thickness x:Key="MarginSidebarList">10,0,10,10</Thickness>
    <Thickness x:Key="MarginResultsHeader">0,0,0,10</Thickness>

    <!-- Paddings standards -->
    <Thickness x:Key="PaddingCard">15</Thickness>
    <Thickness x:Key="PaddingButtonNormal">16,8</Thickness>
    <Thickness x:Key="PaddingButtonSmall">12,4</Thickness>
    <Thickness x:Key="PaddingButtonExecute">20,8</Thickness>
    <Thickness x:Key="PaddingInput">8,5</Thickness>
    <Thickness x:Key="PaddingStatusBar">10,5</Thickness>
    <Thickness x:Key="PaddingTableCell">8,4</Thickness>

    <!-- Dimensions des champs de saisie (Double → pour Width/Height sur contrôles) -->
    <sys:Double x:Key="InputWidth">200</sys:Double>
    <sys:Double x:Key="InputHeight">30</sys:Double>
    <sys:Double x:Key="LabelWidth">150</sys:Double>

    <!-- Dimensions des colonnes résultats (GridLength → pour ColumnDefinition Width) -->
    <GridLength x:Key="ResultLabelWidth">180</GridLength>

    <!-- Dimensions des boutons fenêtre -->
    <sys:Double x:Key="WindowButtonWidth">40</sys:Double>
    <sys:Double x:Key="WindowButtonHeight">30</sys:Double>

    <!-- Rayon des coins -->
    <CornerRadius x:Key="CornerRadiusCard">4</CornerRadius>
    <CornerRadius x:Key="CornerRadiusWindow">8</CornerRadius>
    <CornerRadius x:Key="CornerRadiusTitleBar">8,8,0,0</CornerRadius>

    <!-- Épaisseurs de bordure -->
    <Thickness x:Key="BorderThicknessCard">1</Thickness>
    <Thickness x:Key="BorderThicknessSidebar">0,0,1,0</Thickness>
    <Thickness x:Key="BorderThicknessStatusBar">0,1,0,0</Thickness>
    <Thickness x:Key="BorderThicknessWindow">1</Thickness>

    <!-- Taille icône chargement -->
    <sys:Double x:Key="LoadingIconSize">48</sys:Double>

</ResourceDictionary>
