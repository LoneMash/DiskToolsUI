<!-- Converters.xaml - Version 1.0 -->
<!-- Déclaration centralisée de tous les converters de l'application -->

<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:converters="clr-namespace:RunDeck.Converters">

    <converters:BoolToVisibilityConverter        x:Key="BoolToVisibilityConverter"/>
    <converters:BoolToVisibilityInverseConverter x:Key="BoolToVisibilityInverseConverter"/>
    <converters:EqualityConverter                x:Key="EqualityConverter"/>
    <converters:RequiredFieldBorderConverter     x:Key="RequiredFieldBorderConverter"/>

</ResourceDictionary>
