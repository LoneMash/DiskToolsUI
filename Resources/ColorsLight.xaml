<!-- ColorsLight.xaml - Version 1.0 -->
<!-- Palette claire : fond blanc/gris, accent violet conservé, textes sombres -->

<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Couleurs de fond -->
    <Color x:Key="BackgroundDarkColor">#F0F2F5</Color>
    <Color x:Key="BackgroundMediumColor">#E4E7EC</Color>
    <Color x:Key="BackgroundLightColor">#FFFFFF</Color>
    <Color x:Key="BackgroundInputColor">#FFFFFF</Color>

    <SolidColorBrush x:Key="BackgroundDark"       Color="{StaticResource BackgroundDarkColor}"/>
    <SolidColorBrush x:Key="BackgroundMedium"      Color="{StaticResource BackgroundMediumColor}"/>
    <SolidColorBrush x:Key="BackgroundLight"       Color="{StaticResource BackgroundLightColor}"/>
    <SolidColorBrush x:Key="BackgroundInput"       Color="{StaticResource BackgroundInputColor}"/>

    <!-- Sidebar gradient -->
    <LinearGradientBrush x:Key="SidebarGradient" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#E8EBF0" Offset="0"/>
        <GradientStop Color="#DDE1E8" Offset="1"/>
    </LinearGradientBrush>

    <!-- Couleur d'accentuation : violet/pourpre (identique au dark) -->
    <Color x:Key="AccentStartColor">#6C5CE7</Color>
    <Color x:Key="AccentEndColor">#A855F7</Color>

    <SolidColorBrush x:Key="AccentColor"          Color="#6C5CE7"/>
    <SolidColorBrush x:Key="AccentColorHover"      Color="#7C6CF7"/>
    <SolidColorBrush x:Key="AccentColorPressed"    Color="#5B4BD6"/>

    <LinearGradientBrush x:Key="AccentGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="{StaticResource AccentStartColor}" Offset="0"/>
        <GradientStop Color="{StaticResource AccentEndColor}" Offset="1"/>
    </LinearGradientBrush>

    <!-- Couleurs de texte -->
    <SolidColorBrush x:Key="TextPrimary"          Color="#1A202C"/>
    <SolidColorBrush x:Key="TextSecondary"        Color="#4A5568"/>
    <SolidColorBrush x:Key="TextMuted"            Color="#718096"/>
    <SolidColorBrush x:Key="TextAccent"           Color="#6C5CE7"/>

    <!-- Couleurs de bordure -->
    <SolidColorBrush x:Key="BorderColor"          Color="#CBD5E0"/>
    <SolidColorBrush x:Key="BorderAccent"         Color="#A0AEC0"/>
    <SolidColorBrush x:Key="BorderSubtle"         Color="#E2E8F0"/>

    <!-- Glass card -->
    <SolidColorBrush x:Key="GlassBackground"      Color="#FFFFFF"/>
    <SolidColorBrush x:Key="GlassBorder"          Color="#CBD5E0"/>

    <!-- Couleurs des boutons -->
    <SolidColorBrush x:Key="ButtonBackground"     Color="#EDF2F7"/>
    <SolidColorBrush x:Key="ButtonHover"          Color="#E2E8F0"/>

    <!-- Couleur fermeture fenêtre -->
    <SolidColorBrush x:Key="CloseButtonHover"     Color="#FED7D7"/>
    <SolidColorBrush x:Key="CloseButtonIcon"      Color="#E53E3E"/>

    <!-- Sidebar active item -->
    <LinearGradientBrush x:Key="SidebarActiveBrush" StartPoint="0,0.5" EndPoint="1,0.5">
        <GradientStop Color="#D6BCFA" Offset="0"/>
        <GradientStop Color="Transparent" Offset="1"/>
    </LinearGradientBrush>

    <!-- Overlay chargement -->
    <SolidColorBrush x:Key="LoadingOverlay"       Color="#CCF0F2F5"/>

    <!-- Couleur positive -->
    <SolidColorBrush x:Key="PositiveColor"        Color="#38A169"/>

</ResourceDictionary>
