<!-- Version 3.0                                                              -->
<!-- Changelog :                                                              -->
<!--   1.0 - Initial : TextBox uniquement                                    -->
<!--   3.0 - v3.00 : Affichage description de l'action                      -->
<!--                 Support multi-types : Text, Number, Bool, Dropdown      -->
<!--                 Indicateur visuel * pour paramètres Required            -->
<UserControl x:Class="DiskToolsUi.Views.ParametersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="clr-namespace:DiskToolsUi.Models">

    <Border Background="{StaticResource BackgroundLight}"
            CornerRadius="{StaticResource CornerRadiusCard}"
            Padding="{StaticResource PaddingCard}"
            Margin="{StaticResource MarginSection}"
            BorderBrush="{StaticResource BorderColor}"
            BorderThickness="{StaticResource BorderThicknessCard}"
            Visibility="{Binding IsFormVisible,
                         Converter={StaticResource BoolToVisibilityConverter}}">
        <StackPanel>

            <!-- En-tête -->
            <TextBlock Text="PARAMÈTRES"
                       FontSize="{StaticResource FontSizeSection}"
                       FontWeight="Bold"
                       Foreground="{StaticResource TextMuted}"
                       Margin="{StaticResource MarginItem}"/>

            <!-- Description de l'action -->
            <TextBlock Text="{Binding ActionDescription}"
                       FontSize="{StaticResource FontSizeNormal}"
                       Foreground="{StaticResource TextSecondary}"
                       FontStyle="Italic"
                       TextWrapping="Wrap"
                       Margin="0,0,0,12"
                       Visibility="{Binding ActionDescription,
                                    Converter={StaticResource BoolToVisibilityConverter}}"/>

            <!-- Liste des paramètres -->
            <ItemsControl ItemsSource="{Binding SelectedAction.Parameters}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type models:ParameterDefinition}">
                        <StackPanel Orientation="Horizontal"
                                    Margin="{StaticResource MarginItem}">

                            <!-- Label + indicateur Required -->
                            <StackPanel Orientation="Horizontal"
                                        Width="{StaticResource LabelWidth}"
                                        VerticalAlignment="Center"
                                        Margin="0,0,10,0">
                                <TextBlock Text="{Binding Label}"
                                           Foreground="{StaticResource TextPrimary}"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"/>
                                <TextBlock Text=" *"
                                           Foreground="{StaticResource AccentColor}"
                                           FontWeight="Bold"
                                           VerticalAlignment="Center"
                                           Visibility="{Binding Required,
                                                        Converter={StaticResource BoolToVisibilityConverter}}"/>
                            </StackPanel>

                            <!-- TEXT -->
                            <TextBox Text="{Binding CurrentValue,
                                             UpdateSourceTrigger=PropertyChanged}"
                                     Width="{StaticResource InputWidth}"
                                     Height="{StaticResource InputHeight}"
                                     Background="{StaticResource BackgroundInput}"
                                     Foreground="{StaticResource TextPrimary}"
                                     BorderBrush="{StaticResource BorderAccent}"
                                     BorderThickness="{StaticResource BorderThicknessCard}"
                                     Padding="{StaticResource PaddingInput}"
                                     FontSize="{StaticResource FontSizeNormal}"
                                     VerticalContentAlignment="Center">
                                <TextBox.Style>
                                    <Style TargetType="TextBox">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Type}" Value="Text">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Type}" Value="Number">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>

                            <!-- BOOL → CheckBox -->
                            <CheckBox VerticalAlignment="Center"
                                      Foreground="{StaticResource TextPrimary}"
                                      BorderBrush="{StaticResource BorderAccent}">
                                <CheckBox.IsChecked>
                                    <Binding Path="CurrentValue"
                                             UpdateSourceTrigger="PropertyChanged"
                                             Converter="{StaticResource BoolToVisibilityConverter}"/>
                                </CheckBox.IsChecked>
                                <CheckBox.Style>
                                    <Style TargetType="CheckBox">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Type}" Value="Bool">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </CheckBox.Style>
                            </CheckBox>

                            <!-- DROPDOWN → ComboBox -->
                            <ComboBox ItemsSource="{Binding Options}"
                                      SelectedItem="{Binding CurrentValue,
                                                     UpdateSourceTrigger=PropertyChanged}"
                                      Width="{StaticResource InputWidth}"
                                      Height="{StaticResource InputHeight}"
                                      Background="{StaticResource BackgroundInput}"
                                      Foreground="{StaticResource TextPrimary}"
                                      BorderBrush="{StaticResource BorderAccent}"
                                      BorderThickness="{StaticResource BorderThicknessCard}"
                                      FontSize="{StaticResource FontSizeNormal}"
                                      VerticalContentAlignment="Center">
                                <ComboBox.Style>
                                    <Style TargetType="ComboBox">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Type}" Value="Dropdown">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ComboBox.Style>
                            </ComboBox>

                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Bouton Exécuter -->
            <Button Content="▶ Exécuter"
                    Command="{Binding ExecuteActionCommand}"
                    Style="{StaticResource ExecuteButton}"
                    HorizontalAlignment="Left"
                    Padding="{StaticResource PaddingButtonExecute}"
                    Margin="0,10,0,0"/>

        </StackPanel>
    </Border>
</UserControl>
