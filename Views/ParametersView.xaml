<!-- ParametersView.xaml - Version 5.0 -->
<!-- Style C# Design Pro : glass card, gradient button, rounded inputs -->
<!-- Refs couleurs en DynamicResource pour le switch de thème -->

<UserControl x:Class="RunDeck.Views.ParametersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="clr-namespace:RunDeck.Models">

    <Border Background="{DynamicResource GlassBackground}"
            CornerRadius="{StaticResource CornerRadiusCard}"
            Padding="{StaticResource PaddingCard}"
            Margin="{StaticResource MarginSection}"
            BorderBrush="{DynamicResource GlassBorder}"
            BorderThickness="{StaticResource BorderThicknessCard}"
            Visibility="{Binding IsFormVisible,
                         Converter={StaticResource BoolToVisibilityConverter}}">
        <StackPanel>

            <!-- Label catégorie -->
            <TextBlock Text="PARAMÈTRES"
                       FontSize="{StaticResource FontSizeCategory}"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource TextMuted}"
                       Margin="{StaticResource MarginItem}"
                       />

            <!-- Liste des paramètres -->
            <ItemsControl ItemsSource="{Binding SelectedAction.Parameters}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type models:ParameterDefinition}">
                        <StackPanel Orientation="Horizontal"
                                    Margin="{StaticResource MarginItem}">

                            <!-- Label + indicateur Required -->
                            <StackPanel Orientation="Horizontal"
                                        Width="{StaticResource LabelWidth}"
                                        VerticalAlignment="Center"
                                        Margin="0,0,10,0">
                                <TextBlock Text="{Binding Label}"
                                           Foreground="{DynamicResource TextSecondary}"
                                           VerticalAlignment="Center"
                                           FontSize="{StaticResource FontSizeNormal}"
                                           TextTrimming="CharacterEllipsis"/>
                                <TextBlock Text=" *"
                                           Foreground="{DynamicResource AccentColor}"
                                           FontWeight="Bold"
                                           VerticalAlignment="Center"
                                           Visibility="{Binding Required,
                                                        Converter={StaticResource BoolToVisibilityConverter}}"/>
                            </StackPanel>

                            <!-- TEXT / NUMBER -->
                            <Border CornerRadius="{StaticResource CornerRadiusInput}"
                                    Background="{DynamicResource BackgroundInput}"
                                    BorderThickness="1.5">
                                <Border.BorderBrush>
                                    <MultiBinding Converter="{StaticResource RequiredFieldBorderConverter}">
                                        <Binding Path="Required"/>
                                        <Binding Path="CurrentValue"/>
                                    </MultiBinding>
                                </Border.BorderBrush>
                                <TextBox Text="{Binding CurrentValue,
                                                 UpdateSourceTrigger=PropertyChanged}"
                                         Width="{StaticResource InputWidth}"
                                         Background="Transparent"
                                         Foreground="{DynamicResource TextPrimary}"
                                         BorderThickness="0"
                                         Padding="{StaticResource PaddingInput}"
                                         FontSize="{StaticResource FontSizeNormal}"
                                         VerticalContentAlignment="Center"
                                         CaretBrush="{DynamicResource AccentColor}">
                                    <TextBox.Style>
                                        <Style TargetType="TextBox">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Type}" Value="Text">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Type}" Value="Number">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBox.Style>
                                </TextBox>
                            </Border>

                            <!-- BOOL -->
                            <CheckBox VerticalAlignment="Center"
                                      Foreground="{DynamicResource TextPrimary}"
                                      BorderBrush="{DynamicResource BorderAccent}">
                                <CheckBox.IsChecked>
                                    <Binding Path="CurrentValue"
                                             UpdateSourceTrigger="PropertyChanged"
                                             Converter="{StaticResource BoolToVisibilityConverter}"/>
                                </CheckBox.IsChecked>
                                <CheckBox.Style>
                                    <Style TargetType="CheckBox">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Type}" Value="Bool">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </CheckBox.Style>
                            </CheckBox>

                            <!-- DROPDOWN -->
                            <ComboBox ItemsSource="{Binding Options}"
                                      SelectedItem="{Binding CurrentValue,
                                                     UpdateSourceTrigger=PropertyChanged}"
                                      Width="{StaticResource InputWidth}"
                                      Height="{StaticResource InputHeight}"
                                      Background="{DynamicResource BackgroundInput}"
                                      Foreground="{DynamicResource TextPrimary}"
                                      BorderBrush="{DynamicResource BorderAccent}"
                                      BorderThickness="{StaticResource BorderThicknessCard}"
                                      FontSize="{StaticResource FontSizeNormal}"
                                      VerticalContentAlignment="Center">
                                <ComboBox.Style>
                                    <Style TargetType="ComboBox">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Type}" Value="Dropdown">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ComboBox.Style>
                            </ComboBox>

                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Boutons action -->
            <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                <Button Content="▶  Exécuter"
                        Command="{Binding ExecuteActionCommand}"
                        Style="{DynamicResource ExecuteButton}"
                        Padding="{StaticResource PaddingButtonExecute}"/>
                <Button Content="📥  Export CSV"
                        Command="{Binding ExportCsvCommand}"
                        Style="{DynamicResource ModernButton}"
                        Padding="{StaticResource PaddingButtonSmall}"
                        Margin="10,0,0,0"/>
            </StackPanel>

        </StackPanel>
    </Border>
</UserControl>
