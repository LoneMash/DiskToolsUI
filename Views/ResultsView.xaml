<!-- Version 3.0                                                              -->
<!-- Changelog :                                                              -->
<!--   1.0 - Initial : modes KeyValue et Table                               -->
<!--   3.0 - v3.00 : Ajout mode Log (IsLog = true) — texte brut scrollable  -->
<!--                 Message "Aucun résultat" quand HasResults = false       -->
<UserControl x:Class="DiskToolsUi.Views.ResultsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border Background="{StaticResource BackgroundLight}"
            CornerRadius="{StaticResource CornerRadiusCard}"
            Padding="{StaticResource PaddingCard}"
            BorderBrush="{StaticResource BorderColor}"
            BorderThickness="{StaticResource BorderThicknessCard}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- En-tête + bouton Export -->
            <Grid Grid.Row="0" Margin="{StaticResource MarginResultsHeader}">
                <TextBlock Text="RÉSULTATS"
                           FontSize="{StaticResource FontSizeSection}"
                           FontWeight="Bold"
                           Foreground="{StaticResource TextMuted}"
                           VerticalAlignment="Center"/>
                <Button Content="📥 Exporter CSV"
                        Command="{Binding ExportCsvCommand}"
                        HorizontalAlignment="Right"
                        Style="{StaticResource ModernButton}"
                        Padding="{StaticResource PaddingButtonSmall}"
                        FontSize="{StaticResource FontSizeSection}"
                        Visibility="{Binding HasResults,
                                     Converter={StaticResource BoolToVisibilityConverter}}"/>
            </Grid>

            <!-- Message "Aucun résultat" -->
            <TextBlock Grid.Row="1"
                       Text="Aucun résultat à afficher."
                       Foreground="{StaticResource TextMuted}"
                       FontStyle="Italic"
                       FontSize="{StaticResource FontSizeNormal}"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Visibility="{Binding HasResults,
                                    Converter={StaticResource BoolToVisibilityInverseConverter}}"/>

            <!-- Résultats -->
            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          Visibility="{Binding HasResults,
                                       Converter={StaticResource BoolToVisibilityConverter}}">
                <ItemsControl ItemsSource="{Binding Results}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel>

                                <!-- MODE KEY/VALUE -->
                                <Grid Margin="0,4"
                                      Visibility="{Binding IsTable,
                                                   Converter={StaticResource BoolToVisibilityInverseConverter}}">
                                    <Grid.Style>
                                        <Style TargetType="Grid">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsLog}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Grid.Style>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="180"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding Label}"
                                               Foreground="{StaticResource TextSecondary}"
                                               FontWeight="SemiBold"/>
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding Value}"
                                               Foreground="{StaticResource TextPrimary}"
                                               TextWrapping="Wrap"/>
                                </Grid>

                                <!-- MODE TABLE -->
                                <StackPanel Margin="0,4"
                                            Visibility="{Binding IsTable,
                                                         Converter={StaticResource BoolToVisibilityConverter}}">
                                    <!-- En-têtes -->
                                    <ItemsControl ItemsSource="{Binding Columns}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <UniformGrid Rows="1"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="{StaticResource AccentColor}"
                                                        Padding="{StaticResource PaddingTableCell}"
                                                        Margin="1,0">
                                                    <TextBlock Text="{Binding}"
                                                               Foreground="White"
                                                               FontWeight="Bold"
                                                               FontSize="{StaticResource FontSizeSection}"/>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <!-- Lignes -->
                                    <ItemsControl ItemsSource="{Binding Rows}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border BorderBrush="{StaticResource BorderColor}"
                                                        BorderThickness="0,0,0,1">
                                                    <ItemsControl ItemsSource="{Binding Cells}">
                                                        <ItemsControl.ItemsPanel>
                                                            <ItemsPanelTemplate>
                                                                <UniformGrid Rows="1"/>
                                                            </ItemsPanelTemplate>
                                                        </ItemsControl.ItemsPanel>
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <TextBlock Text="{Binding}"
                                                                           Foreground="{StaticResource TextPrimary}"
                                                                           Padding="{StaticResource PaddingTableCell}"
                                                                           Margin="1,0"
                                                                           TextWrapping="Wrap"/>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>

                                <!-- MODE LOG -->
                                <Border Margin="0,4"
                                        Background="{StaticResource BackgroundDark}"
                                        CornerRadius="{StaticResource CornerRadiusCard}"
                                        Padding="{StaticResource PaddingCard}"
                                        Visibility="{Binding IsLog,
                                                     Converter={StaticResource BoolToVisibilityConverter}}">
                                    <TextBox Text="{Binding RawText, Mode=OneWay}"
                                             IsReadOnly="True"
                                             Background="Transparent"
                                             Foreground="{StaticResource TextPrimary}"
                                             BorderThickness="0"
                                             FontFamily="Consolas, Courier New"
                                             FontSize="{StaticResource FontSizeSmall}"
                                             TextWrapping="Wrap"
                                             AcceptsReturn="True"/>
                                </Border>

                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

        </Grid>
    </Border>
</UserControl>
