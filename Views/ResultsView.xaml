<!-- ResultsView.xaml - Version 7.0 -->
<!-- Style C# Design Pro : glass card, DataGrid stylé, résultats raffinés -->
<!-- Refs couleurs en DynamicResource pour le switch de thème -->
<!-- 7.0 - DataTemplates typés (KeyValueResult, TableResult, LogResult) -->
<!--       Suppression des DataTriggers IsTable/IsLog -->

<UserControl x:Class="RunDeck.Views.ResultsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="clr-namespace:RunDeck.Models">

    <Border Background="{DynamicResource GlassBackground}"
            CornerRadius="{StaticResource CornerRadiusCard}"
            Padding="{StaticResource PaddingCard}"
            BorderBrush="{DynamicResource GlassBorder}"
            BorderThickness="{StaticResource BorderThicknessCard}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- En-tête -->
            <TextBlock Grid.Row="0"
                       Text="RÉSULTATS"
                       FontSize="{StaticResource FontSizeCategory}"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource TextMuted}"
                       Margin="{StaticResource MarginResultsHeader}"
                       />

            <!-- Message "Aucun résultat" -->
            <TextBlock Grid.Row="1"
                       Text="Aucun résultat à afficher."
                       Foreground="{DynamicResource TextMuted}"
                       FontStyle="Italic"
                       FontSize="{StaticResource FontSizeNormal}"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Visibility="{Binding HasResults,
                                    Converter={StaticResource BoolToVisibilityInverseConverter}}"/>

            <!-- Résultats -->
            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          Visibility="{Binding HasResults,
                                       Converter={StaticResource BoolToVisibilityConverter}}">
                <ItemsControl ItemsSource="{Binding Results}">
                    <ItemsControl.Resources>

                        <!-- MODE KEY/VALUE -->
                        <DataTemplate DataType="{x:Type models:KeyValueResult}">
                            <Grid Margin="0,3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="180"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.ColumnSpan="2"
                                        BorderBrush="{DynamicResource BorderSubtle}"
                                        BorderThickness="0,0,0,1"/>
                                <TextBlock Grid.Column="0"
                                           Text="{Binding Label}"
                                           Foreground="{DynamicResource TextSecondary}"
                                           FontSize="{StaticResource FontSizeNormal}"
                                           Padding="0,6"/>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding Value}"
                                           Foreground="{DynamicResource TextPrimary}"
                                           FontWeight="Medium"
                                           FontSize="{StaticResource FontSizeNormal}"
                                           TextWrapping="Wrap"
                                           HorizontalAlignment="Right"
                                           Padding="0,6"/>
                            </Grid>
                        </DataTemplate>

                        <!-- MODE TABLE (DataGrid avec tri natif) -->
                        <DataTemplate DataType="{x:Type models:TableResult}">
                            <DataGrid Margin="0,4"
                                      ItemsSource="{Binding TableView}"
                                      AutoGenerateColumns="True"
                                      CanUserSortColumns="True"
                                      CanUserReorderColumns="False"
                                      CanUserResizeColumns="True"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      IsReadOnly="True"
                                      SelectionMode="Single"
                                      HeadersVisibility="Column"
                                      GridLinesVisibility="Horizontal"
                                      HorizontalGridLinesBrush="{DynamicResource BorderSubtle}"
                                      Background="Transparent"
                                      RowBackground="{DynamicResource GlassBackground}"
                                      AlternatingRowBackground="{DynamicResource BackgroundLight}"
                                      Foreground="{DynamicResource TextPrimary}"
                                      BorderBrush="{DynamicResource GlassBorder}"
                                      BorderThickness="1"
                                      FontSize="{StaticResource FontSizeSection}">
                                <DataGrid.Resources>
                                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#2D2466"/>
                                    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#1E1A4A"/>
                                </DataGrid.Resources>
                                <DataGrid.ColumnHeaderStyle>
                                    <Style TargetType="DataGridColumnHeader">
                                        <Setter Property="Background" Value="{DynamicResource AccentGradient}"/>
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <Setter Property="Padding" Value="{StaticResource PaddingTableCell}"/>
                                        <Setter Property="BorderBrush" Value="{DynamicResource BorderSubtle}"/>
                                        <Setter Property="BorderThickness" Value="0,0,1,0"/>
                                        <Setter Property="Cursor" Value="Hand"/>
                                    </Style>
                                </DataGrid.ColumnHeaderStyle>
                                <DataGrid.CellStyle>
                                    <Style TargetType="DataGridCell">
                                        <Setter Property="Padding" Value="{StaticResource PaddingTableCell}"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Foreground" Value="White"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGrid.CellStyle>
                            </DataGrid>
                        </DataTemplate>

                        <!-- MODE LOG -->
                        <DataTemplate DataType="{x:Type models:LogResult}">
                            <Border Margin="0,4"
                                    Background="{DynamicResource BackgroundDark}"
                                    CornerRadius="{StaticResource CornerRadiusCard}"
                                    Padding="{StaticResource PaddingCard}">
                                <TextBox Text="{Binding RawText, Mode=OneWay}"
                                         IsReadOnly="True"
                                         Background="Transparent"
                                         Foreground="{DynamicResource TextPrimary}"
                                         BorderThickness="0"
                                         FontFamily="Consolas, Courier New"
                                         FontSize="{StaticResource FontSizeSmall}"
                                         TextWrapping="Wrap"
                                         AcceptsReturn="True"
                                         CaretBrush="{DynamicResource AccentColor}"/>
                            </Border>
                        </DataTemplate>

                    </ItemsControl.Resources>
                </ItemsControl>
            </ScrollViewer>

        </Grid>
    </Border>
</UserControl>
