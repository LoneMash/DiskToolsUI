<!-- ResultsView.xaml - Version 5.0 -->
<!-- Style C# Design Pro : glass card, DataGrid stylé, résultats raffinés -->

<UserControl x:Class="RunDeck.Views.ResultsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border Background="{StaticResource GlassBackground}"
            CornerRadius="{StaticResource CornerRadiusCard}"
            Padding="{StaticResource PaddingCard}"
            BorderBrush="{StaticResource GlassBorder}"
            BorderThickness="{StaticResource BorderThicknessCard}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- En-tête -->
            <TextBlock Grid.Row="0"
                       Text="RÉSULTATS"
                       FontSize="{StaticResource FontSizeCategory}"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource TextMuted}"
                       Margin="{StaticResource MarginResultsHeader}"
                       />

            <!-- Message "Aucun résultat" -->
            <TextBlock Grid.Row="1"
                       Text="Aucun résultat à afficher."
                       Foreground="{StaticResource TextMuted}"
                       FontStyle="Italic"
                       FontSize="{StaticResource FontSizeNormal}"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Visibility="{Binding HasResults,
                                    Converter={StaticResource BoolToVisibilityInverseConverter}}"/>

            <!-- Résultats -->
            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          Visibility="{Binding HasResults,
                                       Converter={StaticResource BoolToVisibilityConverter}}">
                <ItemsControl ItemsSource="{Binding Results}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel>

                                <!-- MODE KEY/VALUE -->
                                <Grid Margin="0,3"
                                      Visibility="{Binding IsTable,
                                                   Converter={StaticResource BoolToVisibilityInverseConverter}}">
                                    <Grid.Style>
                                        <Style TargetType="Grid">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsLog}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Grid.Style>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="180"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.ColumnSpan="2"
                                            BorderBrush="{StaticResource BorderSubtle}"
                                            BorderThickness="0,0,0,1"/>
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding Label}"
                                               Foreground="{StaticResource TextSecondary}"
                                               FontSize="{StaticResource FontSizeNormal}"
                                               Padding="0,6"/>
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding Value}"
                                               Foreground="{StaticResource TextPrimary}"
                                               FontWeight="Medium"
                                               FontSize="{StaticResource FontSizeNormal}"
                                               TextWrapping="Wrap"
                                               HorizontalAlignment="Right"
                                               Padding="0,6"/>
                                </Grid>

                                <!-- MODE TABLE (DataGrid avec tri natif) -->
                                <DataGrid Margin="0,4"
                                          ItemsSource="{Binding TableView}"
                                          AutoGenerateColumns="True"
                                          CanUserSortColumns="True"
                                          CanUserReorderColumns="False"
                                          CanUserResizeColumns="True"
                                          CanUserAddRows="False"
                                          CanUserDeleteRows="False"
                                          IsReadOnly="True"
                                          SelectionMode="Single"
                                          HeadersVisibility="Column"
                                          GridLinesVisibility="Horizontal"
                                          HorizontalGridLinesBrush="{StaticResource BorderSubtle}"
                                          Background="Transparent"
                                          RowBackground="{StaticResource GlassBackground}"
                                          AlternatingRowBackground="{StaticResource BackgroundLight}"
                                          Foreground="{StaticResource TextPrimary}"
                                          BorderBrush="{StaticResource GlassBorder}"
                                          BorderThickness="1"
                                          FontSize="{StaticResource FontSizeSection}"
                                          Visibility="{Binding IsTable,
                                                       Converter={StaticResource BoolToVisibilityConverter}}">
                                    <DataGrid.Resources>
                                        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#2D2466"/>
                                        <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#1E1A4A"/>
                                    </DataGrid.Resources>
                                    <DataGrid.ColumnHeaderStyle>
                                        <Style TargetType="DataGridColumnHeader">
                                            <Setter Property="Background" Value="{StaticResource AccentGradient}"/>
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                            <Setter Property="Padding" Value="{StaticResource PaddingTableCell}"/>
                                            <Setter Property="BorderBrush" Value="{StaticResource BorderSubtle}"/>
                                            <Setter Property="BorderThickness" Value="0,0,1,0"/>
                                            <Setter Property="Cursor" Value="Hand"/>
                                        </Style>
                                    </DataGrid.ColumnHeaderStyle>
                                    <DataGrid.CellStyle>
                                        <Style TargetType="DataGridCell">
                                            <Setter Property="Padding" Value="{StaticResource PaddingTableCell}"/>
                                            <Setter Property="BorderThickness" Value="0"/>
                                            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                                            <Style.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter Property="Foreground" Value="White"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </DataGrid.CellStyle>
                                </DataGrid>

                                <!-- MODE LOG -->
                                <Border Margin="0,4"
                                        Background="{StaticResource BackgroundDark}"
                                        CornerRadius="{StaticResource CornerRadiusCard}"
                                        Padding="{StaticResource PaddingCard}"
                                        Visibility="{Binding IsLog,
                                                     Converter={StaticResource BoolToVisibilityConverter}}">
                                    <TextBox Text="{Binding RawText, Mode=OneWay}"
                                             IsReadOnly="True"
                                             Background="Transparent"
                                             Foreground="{StaticResource TextPrimary}"
                                             BorderThickness="0"
                                             FontFamily="Consolas, Courier New"
                                             FontSize="{StaticResource FontSizeSmall}"
                                             TextWrapping="Wrap"
                                             AcceptsReturn="True"
                                             CaretBrush="{StaticResource AccentColor}"/>
                                </Border>

                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

        </Grid>
    </Border>
</UserControl>
