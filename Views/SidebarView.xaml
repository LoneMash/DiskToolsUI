<!-- SidebarView.xaml - Version 1.0 -->
<!-- UserControl gérant la sidebar gauche : liste des actions -->

<UserControl x:Class="DiskToolsUi.Views.SidebarView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border Background="{StaticResource BackgroundMedium}"
            BorderBrush="{StaticResource BorderColor}"
            BorderThickness="{StaticResource BorderThicknessSidebar}">
        <DockPanel>

            <!-- Titre section -->
            <TextBlock DockPanel.Dock="Top"
                       Text="ACTIONS"
                       FontSize="{StaticResource FontSizeSection}"
                       FontWeight="Bold"
                       Foreground="{StaticResource TextMuted}"
                       Margin="{StaticResource MarginSidebarTitle}"/>

            <!-- Liste des actions -->
            <ListBox ItemsSource="{Binding Actions}"
                     SelectedItem="{Binding SelectedAction}"
                     Background="Transparent"
                     BorderThickness="0"
                     Margin="{StaticResource MarginSidebarList}">

                <!-- Supprime le style de sélection natif du ListBoxItem -->
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Padding"    Value="0"/>
                        <Setter Property="Margin"     Value="{StaticResource MarginItem}"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <ContentPresenter/>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>

                <!-- Template d'un bouton d'action -->
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Button Style="{StaticResource SidebarButton}"
                                Command="{Binding DataContext.SelectActionCommand,
                                         RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="{Binding}"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Left">
                            <Button.Content>
                                <TextBlock Text="{Binding Name}"
                                           TextTrimming="CharacterEllipsis"/>
                            </Button.Content>
                            <!-- Couleur bleue si action sélectionnée, grise sinon -->
                            <Button.Background>
                                <MultiBinding Converter="{StaticResource EqualityConverter}">
                                    <Binding Path="DataContext.SelectedAction"
                                             RelativeSource="{RelativeSource AncestorType=Window}"/>
                                    <Binding/>
                                </MultiBinding>
                            </Button.Background>
                        </Button>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

        </DockPanel>
    </Border>
</UserControl>
