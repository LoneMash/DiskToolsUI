<!-- SidebarView.xaml - Version 2.0 -->
<!-- Style C# Design Pro : gradient, logo, catégories groupées, active indicator -->

<UserControl x:Class="RunDeck.Views.SidebarView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border Background="{StaticResource SidebarGradient}"
            BorderBrush="{StaticResource BorderSubtle}"
            BorderThickness="{StaticResource BorderThicknessSidebar}">
        <DockPanel>

            <!-- Logo zone -->
            <Border DockPanel.Dock="Top"
                    BorderBrush="{StaticResource BorderSubtle}"
                    BorderThickness="0,0,0,1"
                    Padding="16,14">
                <StackPanel Orientation="Horizontal">
                    <Border Width="{StaticResource LogoIconSize}"
                            Height="{StaticResource LogoIconSize}"
                            CornerRadius="{StaticResource CornerRadiusButton}"
                            Background="{StaticResource AccentGradient}"
                            Margin="0,0,10,0">
                        <TextBlock Text="⚡"
                                   FontSize="16"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="RunDeck"
                                   FontSize="{StaticResource FontSizeMedium}"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimary}"/>
                        <TextBlock Text="v3.0"
                                   FontSize="{StaticResource FontSizeCategory}"
                                   Foreground="{StaticResource TextMuted}"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Footer : compteur -->
            <Border DockPanel.Dock="Bottom"
                    BorderBrush="{StaticResource BorderSubtle}"
                    BorderThickness="0,1,0,0"
                    Padding="0,8">
                <TextBlock Text="{Binding Actions.Count, StringFormat='{}{0} actions chargées'}"
                           FontSize="{StaticResource FontSizeCategory}"
                           Foreground="{StaticResource TextMuted}"
                           HorizontalAlignment="Center"/>
            </Border>

            <!-- Liste des actions groupées par catégorie -->
            <ListBox ItemsSource="{Binding GroupedActions}"
                     SelectedItem="{Binding SelectedAction}"
                     Background="Transparent"
                     BorderThickness="0"
                     Margin="8,6,8,6"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">

                <!-- Style des groupes (catégories) -->
                <ListBox.GroupStyle>
                    <GroupStyle>
                        <GroupStyle.HeaderTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Name}"
                                           FontSize="{StaticResource FontSizeCategory}"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextMuted}"
                                           Margin="10,10,0,4"
                                           />
                                <!-- Note: le texte des catégories est déjà en majuscules dans actions.json -->
                            </DataTemplate>
                        </GroupStyle.HeaderTemplate>
                    </GroupStyle>
                </ListBox.GroupStyle>

                <!-- Supprime le style natif ListBoxItem -->
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Padding"    Value="0"/>
                        <Setter Property="Margin"     Value="0,1"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <ContentPresenter/>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>

                <!-- Template d'un item d'action -->
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Button Style="{StaticResource SidebarButton}"
                                Command="{Binding DataContext.SelectActionCommand,
                                         RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="{Binding}"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Left">
                            <Button.Content>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Icon}"
                                               FontSize="13"
                                               Opacity="0.6"
                                               VerticalAlignment="Center"
                                               Margin="0,0,8,0"/>
                                    <TextBlock Text="{Binding Name}"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                            </Button.Content>
                            <Button.Background>
                                <MultiBinding Converter="{StaticResource EqualityConverter}">
                                    <Binding Path="DataContext.SelectedAction"
                                             RelativeSource="{RelativeSource AncestorType=Window}"/>
                                    <Binding/>
                                </MultiBinding>
                            </Button.Background>
                        </Button>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

        </DockPanel>
    </Border>
</UserControl>
