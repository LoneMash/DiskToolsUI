<!-- App.xaml - Version 3.0 -->
<!-- Changelog : Déclaration des ResourceDictionary au niveau Application -->
<!--             Rend Colors, Sizes, Converters et Buttons accessibles     -->
<!--             dans tous les UserControls et fenêtres de l'application   -->

<Application x:Class="RunDeck.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Ordre important : Colors en premier car Buttons en dépend -->
                <ResourceDictionary Source="/Resources/Colors.xaml"/>
                <ResourceDictionary Source="/Resources/Sizes.xaml"/>
                <ResourceDictionary Source="/Resources/Converters.xaml"/>
                <ResourceDictionary Source="/Resources/Buttons.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
